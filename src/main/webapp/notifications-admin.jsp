<%@ page import="model.User,model.Notification,service.NotificationService,java.util.*" %><%@ page contentType="text/html;charset=UTF-8" %><% User admin=(User)session.getAttribute("account"); if(admin==null||admin.getRole().equals("CUSTOMER")){response.sendRedirect("login.jsp");return;} NotificationService ns=new NotificationService(); List<Notification> list=ns.all(); %><html><head><title>Send Notifications</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="css/style.css" rel="stylesheet"></head><body><jsp:include page="nav.jsp"/><div class="container-fluid mt-4"><div class="row"><div class="col-md-3"><div class="sidebar p-3 rounded"><a href="admin-dashboard.jsp">Dashboard</a><a href="manage-users.jsp">Manage Customers/Admins</a><a href="packages.jsp">Manage Packages</a><a href="price-list.jsp">Customize Price List</a><a href="bookings.jsp">Bookings</a><a href="payments.jsp">Payment Validation</a><a href="reviews.jsp">Reviews</a><a href="notifications-admin.jsp">Notifications</a><a href="admin-profile.jsp">Admin Profile</a></div></div><div class="col-md-9"><h3 class="section-title">Send User Notifications</h3><div class="card shadow p-4 mb-4"><form action="send-notification" method="post" class="row g-2"><div class="col-md-2"><label>Message ID</label><input name="id" class="form-control" value="N<%=System.currentTimeMillis()%>" required></div><div class="col-md-3"><label>Username</label><input name="username" class="form-control" placeholder="customer username or ALL" required></div><div class="col-md-3"><label>Title</label><input name="title" class="form-control" placeholder="Payment update" required></div><div class="col-md-4"><label>Message</label><input name="message" class="form-control" placeholder="Type message" required></div><div class="col-12"><button class="btn btn-primary">Send Notification</button><button type="reset" class="btn btn-secondary">Clear</button></div></form></div><div class="card shadow p-4"><h5>Notification List</h5><table class="table table-bordered"><tr class="table-dark"><th>ID</th><th>User</th><th>Title</th><th>Message</th><th>Action</th></tr><% for(Notification n:list){%><tr><form action="update-notification" method="post"><td><input name="id" class="form-control" value="<%=n.getId()%>" readonly></td><td><input name="username" class="form-control" value="<%=n.getUsername()%>"></td><td><input name="title" class="form-control" value="<%=n.getTitle()%>"></td><td><input name="message" class="form-control" value="<%=n.getMessage()%>"></td><td><button class="btn btn-sm btn-warning">Update</button></form><form action="delete-notification" method="post" class="d-inline"><input type="hidden" name="id" value="<%=n.getId()%>"><button class="btn btn-sm btn-danger">Delete</button></form></td></tr><%}%></table></div></div></div></div></body></html>
