<%@ page import="model.*,service.*,java.util.*" %><%@ page contentType="text/html;charset=UTF-8" %><% User acc=(User)session.getAttribute("account"); boolean admin=acc!=null&&!acc.getRole().equals("CUSTOMER"); PackageService ps=new PackageService(); PriceListService pls=new PriceListService(); String q=request.getParameter("q"); List<StandardPackage> packs=ps.searchStandard(q); List<CustomPackage> customs=admin?ps.searchCustom(q,null):(acc!=null?ps.searchCustom(q,acc.getUsername()):new ArrayList<CustomPackage>()); %><html><head><title>Packages</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="css/style.css" rel="stylesheet"><script>function price(sel){return parseFloat(sel.options[sel.selectedIndex].dataset.price||0)}function calc(){let h=price(document.getElementById('hotel')),t=price(document.getElementById('transport')),a=price(document.getElementById('activity')),p=parseInt(document.getElementById('persons').value||1);let single=h+t+a;document.getElementById('singlePrice').innerText=single.toFixed(2);document.getElementById('totalPrice').innerText=(single*p).toFixed(2);}</script></head><body onload="calc()"><jsp:include page="nav.jsp"/><div class="container mt-4"><h3 class="section-title">Packages & Customization</h3><form class="row g-2 mb-3"><div class="col-md-10"><input name="q" class="form-control" placeholder="Search package by ID, name, destination or user" value="<%=q==null?"":q%>"></div><div class="col-md-2"><button class="btn btn-primary w-100">Search</button></div></form><% if(admin){%><div class="card p-4 shadow mb-4"><h5>Add Standard Package</h5><form action="add-package" method="post" class="row g-2"><div class="col"><input name="id" class="form-control" placeholder="P001" required></div><div class="col"><input name="name" class="form-control" placeholder="Package Name" required></div><div class="col"><input name="destination" class="form-control" placeholder="Destination" required></div><div class="col"><input type="number" name="duration" class="form-control" placeholder="Days" required></div><div class="col"><input type="number" step="0.01" name="basePrice" class="form-control" placeholder="Single Person Price" required></div><div class="col"><input type="number" step="0.01" name="discount" value="0" class="form-control" placeholder="Discount"></div><div class="col-12"><input name="description" class="form-control" placeholder="Description" required></div><div class="col-12"><button class="btn btn-success">Add Package</button></div></form></div><%}%><div class="row g-3"><% for(StandardPackage p:packs){%><div class="col-md-4"><div class="card shadow p-3 h-100"><h5><%=p.getName()%></h5><p><b>ID:</b> <%=p.getId()%> | <b><%=p.getDestination()%></b> | <%=p.getDuration()%> days</p><p><%=p.getDescription()%></p><p>Single person price: Rs. <b><%=p.calculatePrice()%></b></p><% if(acc!=null&&!admin){%><form action="book-package" method="post"><input type="hidden" name="id" value="B<%=System.currentTimeMillis()%>"><input type="hidden" name="packageId" value="<%=p.getId()%>"><label>Travel Date</label><input type="date" name="travelDate" class="form-control mb-2" required><label>No. of Persons</label><input type="number" name="persons" min="1" class="form-control mb-2" required><button class="btn btn-success w-100">Book Package</button></form><%}%><% if(admin){%><form action="delete-package" method="post" class="mt-2"><input type="hidden" name="id" value="<%=p.getId()%>"><button class="btn btn-danger w-100">Delete Package</button></form><%}%></div></div><%}%></div><% if(acc!=null&&!admin){%><div class="card p-4 shadow mt-4"><h5>Create Customized Package</h5><p class="text-muted">Package name will be saved as <b>Customized</b>. Booking date is auto-created when you book.</p><form action="customize-package" method="post" class="row g-2"><div class="col-md-2"><input name="id" class="form-control" value="C<%=System.currentTimeMillis()%>" required></div><div class="col-md-3"><input name="destination" class="form-control" placeholder="Type destination" required></div><div class="col-md-2"><input type="number" name="duration" class="form-control" placeholder="No. of days" required></div><div class="col-md-2"><input id="persons" oninput="calc()" type="number" name="persons" value="1" min="1" class="form-control" placeholder="Persons" required></div><div class="col-md-3"><select id="hotel" onchange="calc()" name="hotel" class="form-select"><% for(String[] d:pls.byType("HOTEL")){%><option data-price="<%=d[2]%>"><%=d[1]%></option><%}%></select></div><div class="col-md-4"><select id="transport" onchange="calc()" name="transport" class="form-select"><% for(String[] d:pls.byType("TRANSPORT")){%><option data-price="<%=d[2]%>"><%=d[1]%></option><%}%></select></div><div class="col-md-4"><select id="activity" onchange="calc()" name="activity" class="form-select"><% for(String[] d:pls.byType("ACTIVITY")){%><option data-price="<%=d[2]%>"><%=d[1]%></option><%}%></select></div><div class="col-md-4 price-box p-2">Single Person: Rs. <b id="singlePrice">0</b><br>Total: Rs. <b id="totalPrice">0</b></div><div class="col-12"><button class="btn btn-warning">Create Customized Package</button></div></form></div><%}%><div class="card p-4 shadow mt-4"><h5><%=admin?"All Customized Packages":"My Customized Packages"%></h5><table class="table"><tr class="table-dark"><th>ID</th><th>User</th><th>Name</th><th>Destination</th><th>Persons</th><th>Single Price</th><th>Total</th><th>Book</th></tr><% for(CustomPackage c:customs){%><tr><td><%=c.getId()%></td><td><%=c.getUsername()%></td><td><%=c.getName()%></td><td><%=c.getDestination()%></td><td><%=c.getPersons()%></td><td>Rs. <%=c.singlePersonPrice()%></td><td>Rs. <%=c.calculatePrice()%></td><td><% if(acc!=null&&!admin){%><form action="book-package" method="post"><input type="hidden" name="id" value="B<%=System.currentTimeMillis()%>"><input type="hidden" name="packageId" value="<%=c.getId()%>"><input type="hidden" name="persons" value="<%=c.getPersons()%>"><input type="date" name="travelDate" class="form-control mb-1" required><button class="btn btn-success btn-sm">Book</button></form><%}%></td></tr><%}%></table></div></div></body></html>