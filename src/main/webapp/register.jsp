<%@ page contentType="text/html;charset=UTF-8" %><html><head><title>Register</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="css/style.css" rel="stylesheet"><script>function togglePass(id){let x=document.getElementById(id);x.type=x.type==='password'?'text':'password';}</script></head><body><jsp:include page="nav.jsp"/><div class="container mt-5"><div class="card shadow p-4 mx-auto" style="max-width:640px"><h3 class="section-title text-center">Customer Registration</h3><% if(request.getParameter("error")!=null){%><div class="alert alert-danger">Invalid email or duplicate username/email.</div><%}%><form action="register" method="post"><div class="row"><div class="col-md-6"><label>User ID</label><input class="form-control mb-3" name="id" placeholder="U001" required></div><div class="col-md-6"><label>Username</label><input class="form-control mb-3" name="username" required></div></div><label>Email</label><input class="form-control mb-3" type="email" name="email" required><div class="row"><div class="col-md-6"><label>NIC Number</label><input class="form-control mb-3" name="nic" placeholder="200012345678 or 991234567V" required></div><div class="col-md-6"><label>Telephone Number</label><input class="form-control mb-3" name="telephone" pattern="[0-9]{10}" placeholder="0717331406" required></div></div><label>Password</label><div class="input-group mb-3"><input id="regPassword" class="form-control" type="password" name="password" required><button class="btn btn-outline-secondary" type="button" onclick="togglePass('regPassword')">👁</button></div><label>Membership Type</label><select class="form-select mb-3" name="membershipType"><option>Regular</option><option>Premium</option></select><button class="btn btn-primary w-100">Register</button><a href="login.jsp" class="btn btn-dark w-100 mt-2">Already have account? Login</a></form></div></div></body></html>
