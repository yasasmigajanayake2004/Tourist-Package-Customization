<%@ page import="model.*,service.*,java.util.*" %><%@ page contentType="text/html;charset=UTF-8" %><% User acc=(User)session.getAttribute("account"); if(acc==null){response.sendRedirect("login.jsp");return;} boolean admin=!acc.getRole().equals("CUSTOMER"); PaymentService ps=new PaymentService(); BookingService bs=new BookingService(); String q=request.getParameter("q"); List<Payment> list=ps.search(q,admin?null:acc.getUsername()); String bid=request.getParameter("bookingId"); Booking selected=bid==null?null:bs.getById(bid); %><html><head><title>Payments</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="css/style.css" rel="stylesheet"></head><body><jsp:include page="nav.jsp"/><div class="container mt-4"><h3 class="section-title"><%=admin?"Payment Validation Panel":"My Payments"%></h3><% if(request.getParameter("pending")!=null){%><div class="alert alert-warning">Payment submitted. Status is pending until admin validation.</div><%}%><% if(!admin){%><div class="card p-4 shadow mb-4"><h5>Upload Payment Slip</h5><form action="make-payment" method="post" enctype="multipart/form-data" class="row g-2"><div class="col-md-2"><input name="id" class="form-control" value="P<%=System.currentTimeMillis()%>" required></div><div class="col-md-3"><input name="bookingId" class="form-control" placeholder="Booking ID" value="<%=bid==null?"":bid%>" required></div><div class="col-md-2"><input class="form-control" value="Rs. <%=selected==null?"Auto":selected.getAmount()%>" readonly></div><div class="col-md-2"><select name="method" class="form-select"><option>CARD</option><option>ONLINE</option></select></div><div class="col-md-3"><input type="file" name="slip" class="form-control" accept="image/*,.pdf" required></div><div class="col-12"><button class="btn btn-success">Submit Payment For Admin Validation</button></div></form><p class="text-muted mt-2">Amount automatically comes from selected booking/package.</p></div><%}%><form class="row g-2 mb-3"><div class="col-md-10"><input name="q" class="form-control" placeholder="Search payment by ID, booking ID, username, status" value="<%=q==null?"":q%>"></div><div class="col-md-2"><button class="btn btn-primary w-100">Search</button></div></form><div class="card p-4 shadow"><table class="table table-bordered"><tr class="table-dark"><th>ID</th><th>User</th><th>Booking</th><th>Amount</th><th>Method</th><th>Status</th><th>Slip</th><th>Admin Note</th><th>Action</th></tr><% for(Payment p:list){%><tr><td><%=p.getId()%></td><td><%=p.getUsername()%></td><td><%=p.getBookingId()%></td><td>Rs. <%=p.getAmount()%></td><td><%=p.getMethod()%></td><td><span class="badge <%=p.getStatus().equals("APPROVED")?"bg-success":p.getStatus().equals("REJECTED")?"bg-danger":"bg-warning text-dark"%>"><%=p.getStatus()%></span></td><td><%=p.getSlipFile()%></td><td><%=p.getAdminNote()%></td><td><% if(admin&&p.getStatus().equals("PENDING")){%><form action="validate-payment" method="post"><input type="hidden" name="id" value="<%=p.getId()%>"><input name="note" class="form-control mb-1" placeholder="Admin note"><button name="status" value="APPROVED" class="btn btn-success btn-sm">Approve</button><button name="status" value="REJECTED" class="btn btn-danger btn-sm">Reject</button></form><%}else if(admin&&p.getStatus().equals("REJECTED")){%><form action="delete-rejected-payment" method="post"><input type="hidden" name="id" value="<%=p.getId()%>"><button class="btn btn-danger btn-sm">Remove Rejected</button></form><%}else if(!admin&&p.getStatus().equals("REJECTED")){%><a class="btn btn-warning btn-sm" href="payments.jsp?bookingId=<%=p.getBookingId()%>">Pay Again</a><%}%></td></tr><%}%></table></div></div></body></html>