<%@ page import="model.User,service.PriceListService,java.util.*" %><%@ page contentType="text/html;charset=UTF-8" %><% User admin=(User)session.getAttribute("account"); if(admin==null||admin.getRole().equals("CUSTOMER")){response.sendRedirect("login.jsp");return;} PriceListService ps=new PriceListService(); List<String[]> list=ps.all(); %><html><head><title>Price List</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="css/style.css" rel="stylesheet"></head><body><jsp:include page="nav.jsp"/><div class="container mt-4"><h3 class="section-title">Customization Dropdown Price List</h3><div class="card shadow p-4 mb-4"><h5>Add New Dropdown Item</h5><form action="add-price" method="post" class="row g-2"><div class="col"><select name="type" class="form-select"><option>HOTEL</option><option>TRANSPORT</option><option>ACTIVITY</option></select></div><div class="col"><input name="name" class="form-control" placeholder="Item name" required></div><div class="col"><input type="number" step="0.01" name="price" class="form-control" placeholder="Single person price" required></div><div class="col"><button class="btn btn-success w-100">Add Item</button></div></form></div><div class="card shadow p-4"><table class="table table-bordered"><tr class="table-dark"><th>Type</th><th>Name</th><th>Price Per Person</th><th>Action</th></tr><% for(String[] d:list){%><tr><form action="update-price" method="post"><td><input name="type" value="<%=d[0]%>" class="form-control" readonly></td><td><input type="hidden" name="oldName" value="<%=d[1]%>"><input name="name" value="<%=d[1]%>" class="form-control"></td><td><input type="number" step="0.01" name="price" value="<%=d[2]%>" class="form-control"></td><td><button class="btn btn-primary btn-sm">Update</button></form><form action="delete-price" method="post" class="d-inline"><input type="hidden" name="type" value="<%=d[0]%>"><input type="hidden" name="name" value="<%=d[1]%>"><button class="btn btn-danger btn-sm">Delete</button></form></td></tr><%}%></table></div></div></body></html>