<%@ page import="model.User" %><%@ page contentType="text/html;charset=UTF-8" %><% User admin=(User)session.getAttribute("account"); if(admin==null||admin.getRole().equals("CUSTOMER")){response.sendRedirect("login.jsp");return;} %><html><head><title>Admin Profile</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="css/style.css" rel="stylesheet"><script>function togglePass(id){let x=document.getElementById(id);x.type=x.type==='password'?'text':'password';}</script></head><body><jsp:include page="nav.jsp"/><div class="container mt-4"><div class="card shadow p-4"><h3 class="section-title">Admin Profile</h3><p><b>ID:</b> <%=admin.getId()%></p><p><b>Username:</b> <%=admin.getUsername()%></p><p><b>Role:</b> <%=admin.displayType()%></p><% if(!admin.getRole().equals("HEAD_ADMIN")){%><form action="profile-update" method="post"><label>Email</label><input type="email" name="email" value="<%=admin.getEmail()%>" class="form-control mb-3"><label>NIC</label><input name="nic" value="<%=admin.getNic()%>" class="form-control mb-3"><label>Telephone</label><input name="telephone" value="<%=admin.getTelephone()%>" class="form-control mb-3" pattern="[0-9]{10}"><label>Password</label><div class="input-group mb-3"><input id="adminPass" type="password" name="password" value="<%=admin.getPassword()%>" class="form-control"><button type="button" class="btn btn-outline-secondary" onclick="togglePass('adminPass')">👁</button></div><button class="btn btn-primary">Update Admin Profile</button></form><%}else{%><div class="alert alert-warning">Head admin is fixed by special credentials and cannot be edited or deleted.</div><p><b>Contact:</b> 071 733 1406 | headadmin@lankatrails.com</p><%}%></div></div></body></html>
