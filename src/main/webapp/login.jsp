<%@ page contentType="text/html;charset=UTF-8" %><html><head><title>Login</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="css/style.css" rel="stylesheet"><script>function togglePass(id){let x=document.getElementById(id);x.type=x.type==='password'?'text':'password';}</script></head><body><jsp:include page="nav.jsp"/><div class="container mt-5"><div class="row justify-content-center"><div class="col-md-5"><div class="card shadow p-4 portal-card"><h3 class="section-title text-center">Login</h3><p class="text-muted text-center">Customers and admins can use the same login page.</p><% if(request.getParameter("error")!=null){%><div class="alert alert-danger">Invalid username or password.</div><%}%><% if(request.getParameter("deleted")!=null){%><div class="alert alert-success">Account deleted. Login is disabled for that account.</div><%}%><form action="login" method="post"><label>Username</label><input name="username" class="form-control mb-3" required><label>Password</label><div class="input-group mb-3"><input id="loginPassword" type="password" name="password" class="form-control" required><button class="btn btn-outline-secondary" type="button" onclick="togglePass('loginPassword')">👁</button></div><button class="btn btn-primary w-100">Login</button><a href="register.jsp" class="btn btn-dark w-100 mt-2">Customer Registration</a></form><div class="alert alert-light border mt-3 small"><b>Contact Head Admin</b><br>Sadeep Lakshan | 071 733 1406<br>headadmin@lankatrails.com</div></div></div></div></div></body></html>
