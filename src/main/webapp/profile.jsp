<%@ page import="model.User,model.Notification,service.NotificationService,java.util.*" %><%@ page contentType="text/html;charset=UTF-8" %><% User user=(User)session.getAttribute("account"); if(user==null||!user.getRole().equals("CUSTOMER")){response.sendRedirect("login.jsp");return;} NotificationService ns=new NotificationService(); List<Notification> notes=ns.byUser(user.getUsername()); %><html><head><title>Profile</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="css/style.css" rel="stylesheet"><script>function togglePass(id){let x=document.getElementById(id);x.type=x.type==='password'?'text':'password';}</script></head><body><jsp:include page="nav.jsp"/><div class="container-fluid mt-4"><div class="row"><div class="col-md-3"><div class="sidebar p-3 rounded"><a href="profile.jsp">Profile</a><a href="packages.jsp">Packages & Customize</a><a href="bookings.jsp">My Bookings</a><a href="payments.jsp">Payments</a><a href="reviews.jsp">Reviews</a><a href="logout">Logout</a></div></div><div class="col-md-9"><div class="card shadow p-4 mb-4"><h3 class="section-title">Welcome, <%=user.getUsername()%></h3><p><span class="badge badge-soft"><%=user.displayType()%></span></p><% if(request.getParameter("updated")!=null){%><div class="alert alert-success">Profile updated.</div><%}%><form action="profile-update" method="post"><div class="row"><div class="col-md-6"><label>Email</label><input class="form-control mb-3" type="email" name="email" value="<%=user.getEmail()%>" required></div><div class="col-md-6"><label>Telephone</label><input class="form-control mb-3" name="telephone" value="<%=user.getTelephone()%>" pattern="[0-9]{10}" required></div></div><label>NIC Number</label><input class="form-control mb-3" name="nic" value="<%=user.getNic()%>" required><label>Password</label><div class="input-group mb-3"><input id="profilePassword" type="password" class="form-control" name="password" value="<%=user.getPassword()%>" required><button class="btn btn-outline-secondary" type="button" onclick="togglePass('profilePassword')">👁</button></div><label>Membership</label><select class="form-select mb-3" name="membershipType"><option <%=user.getMembershipType().equals("Regular")?"selected":""%>>Regular</option><option <%=user.getMembershipType().equals("Premium")?"selected":""%>>Premium</option></select><button class="btn btn-primary">Update Details</button></form><form action="delete-user" method="post" class="mt-2"><input type="hidden" name="id" value="<%=user.getId()%>"><button class="btn btn-danger" onclick="return confirm('Delete your account?')">Delete My Account</button></form></div><div class="card shadow p-4"><h4 class="section-title">Notifications</h4><% if(notes.isEmpty()){%><p class="text-muted">No notifications yet.</p><%} for(Notification n:notes){%><div class="alert alert-info"><b><%=n.getTitle()%></b><br><%=n.getMessage()%></div><%}%></div></div></div></div></body></html>
