<%@ page import="model.*,service.*,java.util.*" %><%@ page contentType="text/html;charset=UTF-8" %><% User acc=(User)session.getAttribute("account"); if(acc==null){response.sendRedirect("login.jsp");return;} boolean admin=!acc.getRole().equals("CUSTOMER"); BookingService bs=new BookingService(); String q=request.getParameter("q"); List<Booking> list=bs.search(q,admin?null:acc.getUsername()); %><html><head><title>Bookings</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="css/style.css" rel="stylesheet"></head><body><jsp:include page="nav.jsp"/><div class="container mt-4"><h3 class="section-title"><%=admin?"All Booking Details":"My Booking History"%></h3><form class="row g-2 mb-3"><div class="col-md-10"><input name="q" class="form-control" placeholder="Search booking by unique ID, package ID or username" value="<%=q==null?"":q%>"></div><div class="col-md-2"><button class="btn btn-primary w-100">Search</button></div></form><div class="card shadow p-4"><table class="table table-bordered"><tr class="table-dark"><th>ID</th><th>User</th><th>Package</th><th>Booking Date</th><th>Travel Date</th><th>Persons</th><th>Amount</th><th>Status</th><th>Action</th></tr><% for(Booking b:list){%><tr><td><%=b.getId()%></td><td><%=b.getUsername()%></td><td><%=b.getPackageName()%><br><small><%=b.getPackageId()%></small></td><td><%=b.getBookingDate()%></td><td><form action="update-booking" method="post" class="m-0"><input type="hidden" name="id" value="<%=b.getId()%>"><input type="date" name="travelDate" value="<%=b.getTravelDate()%>" class="form-control"></td><td><input type="number" name="persons" value="<%=b.getPersons()%>" min="1" class="form-control"></td><td>Rs. <%=b.getAmount()%></td><td><span class="badge bg-secondary"><%=b.getStatus()%></span></td><td><button class="btn btn-primary btn-sm">Update</button></form><form action="delete-booking" method="post" class="d-inline"><input type="hidden" name="id" value="<%=b.getId()%>"><button class="btn btn-danger btn-sm" onclick="return confirm('Cancel booking?')">Cancel</button></form></td></tr><%}%></table></div></div></body></html>