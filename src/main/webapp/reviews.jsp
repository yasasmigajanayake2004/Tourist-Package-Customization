<%@ page import="service.ReviewService,model.*,java.util.*" %><%@ page contentType="text/html;charset=UTF-8" %><% ReviewService rs=new ReviewService(); List<Review> list=rs.all(); User acc=(User)session.getAttribute("account"); boolean admin=acc!=null&&!acc.getRole().equals("CUSTOMER"); %><html><head><title>Reviews</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="css/style.css" rel="stylesheet"></head><body><jsp:include page="nav.jsp"/><div class="container mt-4"><% if(acc!=null&&!admin){%><div class="card p-4 shadow mb-4"><h3 class="section-title">Submit Review</h3><form action="add-review" method="post" class="row g-2"><div class="col-md-2"><label>Review ID</label><input name="id" class="form-control" value="R<%=System.currentTimeMillis()%>" required></div><div class="col-md-3"><label>Package ID</label><input name="packageId" class="form-control" placeholder="Package ID" required></div><div class="col-md-2"><label>Rating</label><select name="rating" class="form-select"><option>5</option><option>4</option><option>3</option><option>2</option><option>1</option></select></div><div class="col-md-5"><label>Comment</label><input name="comment" class="form-control" placeholder="Write your review" required></div><div class="col-12"><button class="btn btn-primary">Submit Review</button><button type="reset" class="btn btn-secondary">Clear Review Form</button></div></form></div><%}%><div class="card p-4 shadow"><h3 class="section-title"><%=admin?"Admin Review Panel":"Review Listing"%></h3><table class="table"><tr class="table-dark"><th>ID</th><th>User</th><th>Package</th><th>Rating</th><th>Comment</th><th>Action</th></tr><% for(Review r:list){%><tr><td><%=r.getId()%></td><td><%=r.getUsername()%></td><td><%=r.getPackageId()%></td><% if(acc!=null&&!admin&&r.getUsername().equals(acc.getUsername())){%><form action="update-review" method="post"><input type="hidden" name="id" value="<%=r.getId()%>"><input type="hidden" name="packageId" value="<%=r.getPackageId()%>"><td><select name="rating" class="form-select"><% for(int i=5;i>=1;i--){%><option <%=r.getRating()==i?"selected":""%>><%=i%></option><%}%></select></td><td><input name="comment" value="<%=r.getComment()%>" class="form-control"></td><td><button class="btn btn-primary btn-sm">Edit Review</button></form><form action="delete-review" method="post" class="d-inline"><input type="hidden" name="id" value="<%=r.getId()%>"><button class="btn btn-danger btn-sm">Delete Review</button></form></td><%}else{%><td><%=r.getRating()%></td><td><%=r.getComment()%></td><td><% if(admin){%><form action="delete-review" method="post"><input type="hidden" name="id" value="<%=r.getId()%>"><button class="btn btn-danger btn-sm">Admin Delete</button></form><%}%></td><%}%></tr><%}%></table></div></div></body></html>