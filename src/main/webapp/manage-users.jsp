<%@ page import="model.User,service.UserService,java.util.*" %><%@ page contentType="text/html;charset=UTF-8" %><% User admin=(User)session.getAttribute("account"); if(admin==null||admin.getRole().equals("CUSTOMER")){response.sendRedirect("login.jsp");return;} boolean head=admin.getRole().equals("HEAD_ADMIN"); UserService us=new UserService(); String q=request.getParameter("q"); List<User> customers=(q==null||q.isEmpty())?us.getCustomers():us.search(q,"CUSTOMER"); List<User> admins=(q==null||q.isEmpty())?us.getSubAdmins():us.search(q,"SUB_ADMIN"); %><html><head><title>Manage Users</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"><link href="css/style.css" rel="stylesheet"></head><body><jsp:include page="nav.jsp"/><div class="container-fluid mt-4"><div class="row"><div class="col-md-3"><div class="sidebar p-3 rounded"><a href="admin-dashboard.jsp">Dashboard</a><a href="manage-users.jsp">Manage Customers/Admins</a><a href="packages.jsp">Manage Packages</a><a href="price-list.jsp">Customize Price List</a><a href="bookings.jsp">Bookings</a><a href="payments.jsp">Payment Validation</a><a href="reviews.jsp">Reviews</a><a href="notifications-admin.jsp">Notifications</a><a href="admin-profile.jsp">Admin Profile</a></div></div><div class="col-md-9"><h3 class="section-title">Manage Customers and Co Admins</h3><form class="row g-2 mb-3"><div class="col-md-10"><input name="q" class="form-control" placeholder="Search by unique ID, username or email" value="<%=q==null?"":q%>"></div><div class="col-md-2"><button class="btn btn-primary w-100">Search</button></div></form><% if(head){%><div class="card shadow p-4 mb-4"><h5>Add Co Admin</h5><form action="create-subadmin" method="post" class="row g-2"><div class="col-md-2"><input name="id" class="form-control" placeholder="A002" required></div><div class="col-md-2"><input name="username" class="form-control" placeholder="Username" required></div><div class="col-md-3"><input type="email" name="email" class="form-control" placeholder="Email" required></div><div class="col-md-2"><input name="nic" class="form-control" placeholder="NIC" required></div><div class="col-md-2"><input name="telephone" class="form-control" placeholder="Telephone" pattern="[0-9]{10}" required></div><div class="col-md-2"><input name="password" class="form-control" placeholder="Password" required></div><div class="col-md-2"><button class="btn btn-warning w-100">Register</button></div></form></div><%}%><div class="card shadow p-4 mb-4"><h5>Co Admin List</h5><table class="table table-bordered table-sm"><tr class="table-dark"><th>ID</th><th>Username</th><th>Email</th><th>NIC</th><th>Telephone</th><th>Password</th><th>Action</th></tr><% for(User u:admins){%><tr><form action="admin-update-user" method="post"><td><input name="id" value="<%=u.getId()%>" class="form-control" readonly><input type="hidden" name="role" value="SUB_ADMIN"></td><td><input name="username" value="<%=u.getUsername()%>" class="form-control" readonly></td><td><input type="email" name="email" value="<%=u.getEmail()%>" class="form-control"></td><td><input name="nic" value="<%=u.getNic()%>" class="form-control"></td><td><input name="telephone" value="<%=u.getTelephone()%>" class="form-control"></td><td><input name="password" value="<%=u.getPassword()%>" class="form-control"></td><td><button class="btn btn-sm btn-warning">Update</button></form><% if(head){%><form action="delete-user" method="post" class="d-inline"><input type="hidden" name="id" value="<%=u.getId()%>"><button class="btn btn-sm btn-danger">Delete</button></form><%}%></td></tr><%}%></table></div><div class="card shadow p-4"><h5>Customer List</h5><table class="table table-bordered table-sm"><tr class="table-dark"><th>ID</th><th>Username</th><th>Email</th><th>NIC</th><th>Telephone</th><th>Membership</th><th>Password</th><th>Action</th></tr><% for(User u:customers){%><tr><form action="admin-update-user" method="post"><td><input name="id" value="<%=u.getId()%>" class="form-control" readonly><input type="hidden" name="role" value="CUSTOMER"></td><td><input name="username" value="<%=u.getUsername()%>" class="form-control" readonly></td><td><input type="email" name="email" value="<%=u.getEmail()%>" class="form-control"></td><td><input name="nic" value="<%=u.getNic()%>" class="form-control"></td><td><input name="telephone" value="<%=u.getTelephone()%>" class="form-control"></td><td><select name="membershipType" class="form-select"><option <%=u.getMembershipType().equals("Regular")?"selected":""%>>Regular</option><option <%=u.getMembershipType().equals("Premium")?"selected":""%>>Premium</option></select></td><td><input name="password" value="<%=u.getPassword()%>" class="form-control"></td><td><button class="btn btn-sm btn-warning">Update</button></form><form action="delete-user" method="post" class="d-inline"><input type="hidden" name="id" value="<%=u.getId()%>"><button class="btn btn-sm btn-danger">Delete</button></form></td></tr><%}%></table></div></div></div></div></body></html>
